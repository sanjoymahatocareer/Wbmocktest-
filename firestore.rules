rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Subscriptions collection rules
    match /subscriptions/{userId} {
      allow read, write: if true;
    }

    // Payments collection rules
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Settings collection rules
    match /settings/{document=**} {
      allow read, write: if true;
    }

    // Server-managed collections
    match /purchases/{purchaseId} {
      allow read, write: if true;
    }

    match /payment_orders/{orderId} {
      allow read, write: if true;
    }

    match /payment_transactions/{transactionId} {
      allow read, write: if true;
    }

    match /audit_logs/{auditId} {
      allow read, write: if true;
    }

    match /webhook_events/{eventId} {
      allow read, write: if true;
    }

    match /coupons/{couponId} {
      allow read, write: if true;
    }

    match /mock_test_series/{seriesId} {
      allow read, write: if true;
    }

    match /push_subscriptions/{subId} {
      allow read, write: if true;
    }

    // Users Gamification collection rules
    match /users_gamification/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // Leaderboard collection rules
    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }
  }
}
