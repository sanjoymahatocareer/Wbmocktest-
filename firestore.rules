rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Subscriptions collection rules
    match /subscriptions/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
      allow write: if isSignedIn();
    }

    // Payments collection rules
    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    // Settings collection rules
    match /settings/{document=**} {
      allow read, write: if true;
    }

    // Users Gamification collection rules
    match /users_gamification/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // Leaderboard collection rules
    match /leaderboard/{userId} {
      allow get, list: if isSignedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }
  }
}
